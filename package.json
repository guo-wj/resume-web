{
  "name": "resume-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "./scripts/npm-install.sh install",
    "dev": "vite --mode dev",
    "build": "tsc -b && vite build --mode prod",
    "deploy": "npm run build && ./deploy.sh --skip-build",
    "preview": "vite preview --mode prod",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "antd": "^5.24.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.1.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "react-grab": "^0.1.37",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-checker": "^0.13.0"
  }
}
